# ────────────────────────────────────────
# Sentinel ADR — переменные окружения
# Скопируйте в .env и заполните значения
# ────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_secret
POSTGRES_DB=sentinel_adr
POSTGRES_PORT=5432

# Строка подключения для backend (формируется автоматически в docker-compose)
DATABASE_URL=postgresql://sentinel:sentinel_secret@db:5432/sentinel_adr

# URL backend API (используется Vite при сборке фронтенда)
# Локально:    http://localhost:8000
# Docker:      http://localhost:8000
VITE_API_URL=http://localhost:8000

# Схема PostgreSQL (оставить public для локальной БД)
DB_SCHEMA=public
